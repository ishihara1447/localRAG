# =============================================================
# LocalRAG Windows native PoC — server/.env テンプレート
# =============================================================
# 使い方: このファイルを anything-llm/server/.env にコピーして値を調整する。
# runtime/docker-compose.yml の環境変数を Windows native 向けに読み替えたもの。
# シークレット類 (SIG_KEY / SIG_SALT / JWT_SECRET) は初回起動時に自動生成され
# この .env に自動追記されるため、手動設定は不要。

NODE_ENV=production
SERVER_PORT=3001

# ストレージ (絶対パス・末尾スラッシュなし)。存在しない場合は事前に作成すること。
# 例: C:\LocalRAG\storage
STORAGE_DIR=C:\LocalRAG\storage

# --- LLM (Ollama for Windows, native→native なので 127.0.0.1) ---
LLM_PROVIDER=ollama
OLLAMA_BASE_PATH=http://127.0.0.1:11434
OLLAMA_MODEL_PREF=hf.co/mmnga-o/llm-jp-4-8b-thinking-gguf:Q4_K_M
OLLAMA_MODEL_TOKEN_LIMIT=8192
OLLAMA_RESPONSE_TIMEOUT=1200000

# --- Embedding (Docker版で正式採用済みの mxbai-embed-large) ---
EMBEDDING_ENGINE=ollama
EMBEDDING_BASE_PATH=http://127.0.0.1:11434
EMBEDDING_MODEL_PREF=mxbai-embed-large:latest
EMBEDDING_MODEL_MAX_CHUNK_LENGTH=500

# --- Vector DB (内蔵 LanceDB) ---
VECTOR_DB=lancedb

# --- ハードニング既定値 (Docker版と同一。配布計画の絶対ルール) ---
DISABLE_TELEMETRY=true
DISABLE_SWAGGER_DOCS=true
WORKSPACE_DELETION_PROTECTION=1
HF_HUB_OFFLINE=1
