# LocalRAG server/.env - generated by install.ps1 (do not edit unless instructed).
# {{INSTALL_ROOT}} and {{SERVER_PORT}} are replaced at install time.
# Secrets (SIG_KEY / SIG_SALT / JWT_SECRET) are auto-generated on first boot.

NODE_ENV=production
SERVER_PORT={{SERVER_PORT}}
# SERVER_HOST/COLLECTOR_HOSTは意図的に未設定（コード既定の127.0.0.1を使う）。
# これによりサーバー(3001)・collector(8888)ともLAN越しに到達不可能になる
# （2026-07-15、管理者パスワード未設定時に/system/api-keysが誰でも読める
# 脆弱性の修正。詳細: docs/API_KEY_EXPOSURE_FIX_2026-07-15.md）。

# Prisma resolves the SQLite DB relative to the source tree (server\storage),
# so STORAGE_DIR must stay at app\server\storage.
STORAGE_DIR={{INSTALL_ROOT}}\app\server\storage
COLLECTOR_HOTDIR_PATH={{INSTALL_ROOT}}\app\collector\hotdir

# --- LLM (dedicated LocalRAG Ollama service on 11435) ---
LLM_PROVIDER=ollama
OLLAMA_BASE_PATH=http://127.0.0.1:11435
OLLAMA_MODEL_PREF=gemma4:12b
OLLAMA_MODEL_TOKEN_LIMIT=8192
OLLAMA_RESPONSE_TIMEOUT=1200000

# --- Embedding ---
EMBEDDING_ENGINE=ollama
EMBEDDING_BASE_PATH=http://127.0.0.1:11435
EMBEDDING_MODEL_PREF=bge-m3:latest
EMBEDDING_MODEL_MAX_CHUNK_LENGTH=500

# --- Vector DB (built-in LanceDB) ---
VECTOR_DB=lancedb
# 日本語bi-gram BM25とdense検索をRRFで融合する機能。
# 2026-07-14/15の検証で検索漏れ2件が解消(retrieval 2/2)、E2E 11/11・文書外5/5維持を確認し既定ONに確定。
# 残る回答失敗はLLM(gemma4)の抽出問題で検索方式に依らない。詳細: docs/HYBRID_SEARCH_LINUX_VERIFY_RESULT_2026-07-15.md
LANCE_HYBRID_SEARCH=true

# 検索後のチャンクを文単位で再順位付けし、上位文と隣接文だけをLLMへ渡す。
# 防衛白書のフェア再評価でbaseline 18-19/30から24-25/30へ改善。
LANCE_SENTENCE_CUSHION=true
# 配布同梱は約571MBのint8 ONNXのみ。falseにすると未同梱fp32を要求するため変更禁止。
RERANKER_QUANTIZED=true

# --- Hardening defaults (same as the Docker build; non-negotiable) ---
DISABLE_TELEMETRY=true
DISABLE_SWAGGER_DOCS=true
WORKSPACE_DELETION_PROTECTION=1

# 新規ワークスペースの検索既定値 (fork ae678e28で追加。日本語複数文書での検索不足対策)
WORKSPACE_DEFAULT_TOP_N=8
HF_HUB_OFFLINE=1

# --- Local service control (Web UIからの各サービス起動/停止) ---
# ServerはLocalSystemで動くWindowsサービスのため sc.exe でOllama/Collectorを制御できる。
# winsw以外の値/未設定なら制御機能は無効(状態表示のみ)。
LOCAL_SERVICE_CONTROL=winsw
LLM_SERVICE_NAME=LocalRAG-Ollama
COLLECTOR_SERVICE_NAME=LocalRAG-Collector
