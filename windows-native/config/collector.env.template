# LocalRAG collector/.env - generated by install.ps1 (do not edit unless instructed).
# {{INSTALL_ROOT}} is replaced at install time.

NODE_ENV=production
STORAGE_DIR={{INSTALL_ROOT}}\app\server\storage
COLLECTOR_HOTDIR_PATH={{INSTALL_ROOT}}\app\collector\hotdir
# COLLECTOR_HOSTは意図的に未設定（コード既定の127.0.0.1でLAN越しの到達を遮断。
# 2026-07-15、serverの/system/api-keys露出脆弱性修正と合わせて対応）。

# Web link scraping (puppeteer/Chromium) is excluded from this build.
DISABLE_WEB_SCRAPING=true
