# =============================================================
# LocalRAG Windows native PoC — collector/.env テンプレート
# =============================================================
# 使い方: このファイルを anything-llm/collector/.env にコピーして値を調整する。
# collector は server とは別プロセスで、.env も共有しない (各自の cwd から読む)。

NODE_ENV=production

# server 側の STORAGE_DIR と同一の絶対パスを指定すること (documents/ 配下を共有する)
STORAGE_DIR=C:\LocalRAG\storage

# Webリンク取り込み (puppeteer/Chromium依存) を遮断する。
# Windows native 配布では puppeteer を node_modules から除外するため必須。
# fork commit cdd1c292 (DISABLE_WEB_SCRAPING) 参照。
DISABLE_WEB_SCRAPING=true
